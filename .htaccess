DirectoryIndex login.php index.php
Options -Indexes

# Block sensitive folders only
RedirectMatch 403 /(config|includes|database|core|auth)/
# Allow these files WITHOUT redirect 
RewriteCond %{REQUEST_URI} !login.php 
# ALLOW login.php explicitly
# -----------------------------

# Custom error pages
ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
RewriteEngine On
RewriteRule ^tickets/([0-9]+)$ ticket/view.php?ticket_id=$1 [L,QSA]